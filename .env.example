# RadioFlow - Variables de Entorno para Producción
# Copia este archivo a .env y configura las variables

# ===== NEXTAUTH CONFIGURATION =====
# Secreto para firmar tokens JWT (cambiar en producción)
NEXTAUTH_SECRET=tu-secreto-super-seguro-aqui

# URL base de la aplicación
# Para IP directa: http://TU_IP:3000
# Para dominio: https://tu-dominio.com
NEXTAUTH_URL=http://localhost:3000

# ===== DATABASE =====
# SQLite database path (relativo al contenedor)
DATABASE_URL=file:/app/db/custom.db

# ===== ICECAST STREAMING =====
# Contraseña para source (conexión de streaming)
ICECAST_SOURCE_PASSWORD=tu-password-source

# Contraseña de admin de Icecast
ICECAST_ADMIN_PASSWORD=tu-password-admin

# Contraseña para relay
ICECAST_RELAY_PASSWORD=tu-password-relay
